{
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.sleeper.com)",
      "Bash(bundle exec rspec*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git commit -m*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(mkdir -p*)",
      "Bash(pbcopy*)",
      "Bash(bundle exec rake release)",
      "Bash(bundle exec rake standard:fix 2>&1)",
      "Bash(bundle exec rake standard 2>&1)",
      "Bash(bundle exec rake 2>&1 | tail*)"
    ]
  }
}
